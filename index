<script>
const SUPABASE_URL = 'https://fnprdmhkzbzjhxzjcpgd.supabase.co';
const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZucHJkbWhremJ6amh4empjcGdkIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODI4NDE0NzMsImV4cCI6MjA5ODQxNzQ3M30.yEca0RuT2z4iFvQVJtXHbhRCCTc0hhWhfbsIyPWNQPE';
const { createClient } = supabase;
