// ---- NAVIGATION ----
function navigate(view) {
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('view-' + view).classList.add('active');
  document.querySelectorAll('.nav-item').forEach(n => { if (n.getAttribute('onclick') && n.getAttribute('onclick').includes(view)) n.classList.add('active'); });
  const titles = { overview: 'Visão geral', orders: 'Pedidos', customers: 'Clientes', financial: 'Faturamento', costs: 'Custos' };
  document.getElementById('topbar-title').textContent = titles[view] || view;
  const primaryBtn = document.getElementById('topbar-primary-btn');
  const secondaryBtn = document.getElementById('topbar-secondary-btn');
  if (view === 'customers') { primaryBtn.textContent = '+ Novo cliente'; secondaryBtn.style.display = 'none'; }
  else if (view === 'orders') { primaryBtn.textContent = '+ Novo pedido'; secondaryBtn.style.display = 'none'; }
  else { primaryBtn.textContent = '+ Novo pedido'; secondaryBtn.style.display = 'none'; }
  if (view === 'financial') loadFinancial();
  if (view === 'costs') loadCosts();
  if (view === 'orders') renderOrdersTable(allOrders);
  if (view === 'customers') renderCustomersTable(allCustomers);
}

function handlePrimaryAction() {
  const active = document.querySelector('.nav-item.active');
  if (active && active.getAttribute('onclick') && active.getAttribute('onclick').includes('customers')) openModal('modal-customer');
  else openModal('modal-order');
}

// ---- MODALS ----
function openModal(id) { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }

// ---- TOAST ----
function toast(msg, type = 'success') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast toast-' + type + ' show';
  setTimeout(() => t.classList.remove('show'), 3000);
}

// ---- FORMAT ----
const R = n => 'R$ ' + (Number(n) || 0).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
const fmtDate = d => d ? new Date(d).toLocaleDateString('pt-BR') : '—';
const initials = name => name ? name.split(' ').slice(0, 2).map(w => w[0]).join('').toUpperCase() : '??';

function badgeStatus(s) {
  const cls = s === 'entregue_cliente' ? 'badge-green' : s.includes('rota') || s.includes('fabrica') ? 'badge-orange' : 'badge-gold';
  return '<span class="badge ' + cls + '">' + (STATUSES[s] || s) + '</span>';
}

// ---- LOAD ALL DATA ----
async function loadAll() {
  const [ordRes, custRes] = await Promise.all([
    db.from('orders').select('*, customers(name), order_items(*)').order('order_number', { ascending: false }),
    db.from('customers').select('*').order('created_at', { ascending: false })
  ]);
  allOrders = ordRes.data || [];
  allCustomers = custRes.data || [];
  renderOverview();
  renderOrdersTable(allOrders);
  renderCustomersTable(allCustomers);
}

// ---- OVERVIEW ----
function renderOverview() {
  const now = new Date();
  const thisMonth = allOrders.filter(o => new Date(o.created_at).getMonth() === now.getMonth() && new Date(o.created_at).getFullYear() === now.getFullYear());
  let rev = 0, cost = 0, freight = 0;
  thisMonth.forEach(o => { o.order_items.forEach(i => { rev += i.sale_price * i.quantity; cost += i.cost_price * i.quantity; }); freight += Number(o.shipping_cost); });
  const profit = rev - cost - freight;
  const margin = rev > 0 ? ((profit / rev) * 100).toFixed(1) : 0;
  document.getElementById('kpi-revenue').textContent = R(rev);
  document.getElementById('kpi-revenue-sub').textContent = thisMonth.length + ' pedidos este mês';
  document.getElementById('kpi-profit').textContent = R(profit);
  document.getElementById('kpi-margin-sub').textContent = 'Margem: ' + margin + '%';
  document.getElementById('kpi-orders').textContent = allOrders.length;
  const pending = allOrders.filter(o => o.status !== 'entregue_cliente').length;
  document.getElementById('kpi-orders-sub').textContent = pending + ' em andamento';
  document.getElementById('kpi-customers').textContent = allCustomers.length;
  const newCust = allCustomers.filter(c => new Date(c.created_at).getMonth() === now.getMonth()).length;
  document.getElementById('kpi-customers-sub').textContent = newCust + ' novos este mês';
  renderSalesChart();
  renderStatusSummary();
  renderRecentOrders();
}

function renderSalesChart() {
  const months = [], data = [];
  for (let i = 5; i >= 0; i--) {
    const d = new Date(); d.setMonth(d.getMonth() - i);
    const label = d.toLocaleString('pt-BR', { month: 'short' });
    const total = allOrders.filter(o => { const od = new Date(o.created_at); return od.getMonth() === d.getMonth() && od.getFullYear() === d.getFullYear(); }).reduce((acc, o) => acc + o.order_items.reduce((a, i) => a + i.sale_price * i.quantity, 0), 0);
    months.push(label); data.push(total);
  }
  if (chartSales) chartSales.destroy();
  chartSales = new Chart(document.getElementById('chart-sales'), {
    type: 'bar',
    data: { labels: months, datasets: [{ data, backgroundColor: data.map((_, i) => i === 5 ? '#D4AF37' : '#2a2000'), borderRadius: 4, borderSkipped: false }] },
    options: { plugins: { legend: { display: false } }, scales: { x: { ticks: { color: '#555', font: { family: 'Barlow', size: 11 } }, grid: { display: false } }, y: { ticks: { color: '#555', font: { size: 11 }, callback: v => 'R$' + (v/1000).toFixed(0) + 'k' }, grid: { color: '#1a1a1a' } } }, responsive: true, maintainAspectRatio: true }
  });
}

function renderStatusSummary() {
  const counts = {};
  STATUS_KEYS.forEach(k => counts[k] = 0);
  allOrders.forEach(o => { if (counts[o.status] !== undefined) counts[o.status]++; });
  const groups = [
    { label: 'Em trânsito', keys: ['em_rota_brasil', 'chegou_brasil', 'imposto_pago', 'saiu_fabrica', 'encaminhado_fornecedor'], color: '#F25C05' },
    { label: 'Em conferência', keys: ['em_conferencia_tr4'], color: '#D4AF37' },
    { label: 'Entregues', keys: ['entregue_cliente'], color: '#4caf7d' },
    { label: 'Aguardando', keys: ['pedido_solicitado'], color: '#888' },
  ];
  const total = allOrders.length || 1;
  document.getElementById('status-summary').innerHTML = groups.map(g => {
    const count = g.keys.reduce((a, k) => a + (counts[k] || 0), 0);
    const pct = Math.round((count / total) * 100);
    return '<div class="status-bar-row"><span class="status-bar-label">' + g.label + '</span><div class="status-bar-right"><div class="status-bar-track"><div class="status-bar-fill" style="width:' + pct + '%;background:' + g.color + ';"></div></div><span style="font-size:11px;color:' + g.color + ';min-width:16px;text-align:right;">' + count + '</span></div></div>';
  }).join('');
}

function renderRecentOrders() {
  const rows = allOrders.slice(0, 8).map(o => {
    const total = o.order_items.reduce((a, i) => a + i.sale_price * i.quantity, 0);
    const prod = o.order_items.length > 0 ? o.order_items[0].product_description + (o.order_items.length > 1 ? ' +' + (o.order_items.length - 1) : '') : '—';
    return '<tr onclick="showOrderDetail(' + JSON.stringify(o).replace(/"/g, '&quot;') + ')" style="cursor:pointer"><td class="order-num">TR4 #' + String(o.order_number).padStart(3, '0') + '</td><td>' + (o.customers?.name || '—') + '</td><td style="color:#888;font-size:12px;">' + prod + '</td><td>' + badgeStatus(o.status) + '</td><td style="color:#888;">' + (o.payment_method === 'pix' ? 'Pix' : 'Cartão') + '</td><td style="text-align:right;color:var(--gold);font-weight:600;">' + R(total) + '</td></tr>';
  }).join('') || '<tr><td colspan="6" class="empty"><p>Nenhum pedido ainda.</p></td></tr>';
  document.getElementById('recent-orders-body').innerHTML = rows;
}

// ---- ORDERS TABLE ----
function renderOrdersTable(orders) {
  document.getElementById('orders-body').innerHTML = orders.length ? orders.map(o => {
    const total = o.order_items.reduce((a, i) => a + i.sale_price * i.quantity, 0);
    return '<tr onclick="showOrderDetail(' + JSON.stringify(o).replace(/"/g, '&quot;') + ')" style="cursor:pointer"><td class="order-num">TR4 #' + String(o.order_number).padStart(3, '0') + '</td><td>' + (o.customers?.name || '—') + '</td><td style="color:#888;">' + o.order_items.length + ' item(ns)</td><td>' + badgeStatus(o.status) + '</td><td style="color:#888;">' + (o.payment_method === 'pix' ? 'Pix' : 'Cartão') + '</td><td style="color:#888;">' + fmtDate(o.created_at) + '</td><td style="text-align:right;color:var(--gold);font-weight:600;">' + R(total) + '</td></tr>';
  }).join('') : '<tr><td colspan="7" class="empty"><p>Nenhum pedido cadastrado.</p></td></tr>';
}

function filterOrders(q) {
  const f = allOrders.filter(o => (o.customers?.name || '').toLowerCase().includes(q.toLowerCase()) || String(o.order_number).includes(q));
  renderOrdersTable(f);
}

// ---- CUSTOMERS TABLE ----
function renderCustomersTable(customers) {
  document.getElementById('customers-body').innerHTML = customers.length ? customers.map(c =>
    '<tr><td><div class="customer-cell"><div class="avatar">' + initials(c.name) + '</div><div><div style="font-weight:500;">' + c.name + '</div><div style="font-size:11px;color:#666;">' + (c.cpf || '') + '</div></div></div></td><td style="color:#888;">' + (c.phone || '—') + '</td><td style="color:#888;">' + (c.favorite_team || '—') + '</td><td style="color:#888;">' + (c.city || '—') + '</td><td style="color:#888;">' + fmtDate(c.created_at) + '</td></tr>'
  ).join('') : '<tr><td colspan="5" class="empty"><p>Nenhum cliente cadastrado ainda.</p></td></tr>';
}

function filterCustomers(q) {
  const f = allCustomers.filter(c => c.name.toLowerCase().includes(q.toLowerCase()) || (c.cpf || '').includes(q));
  renderCustomersTable(f);
}

// ---- FINANCIAL ----
async function loadFinancial() {
  const { data } = await db.from('order_financials').select('*, orders(customers(name), payment_method)');
  if (!data) return;
  let ts = 0, tc = 0, tp = 0;
  data.forEach(r => { ts += Number(r.total_sale); tc += Number(r.total_cost) + Number(r.shipping_cost); tp += Number(r.profit); });
  const tm = ts > 0 ? ((tp / ts) * 100).toFixed(1) : 0;
  document.getElementById('fin-total-sale').textContent = R(ts);
  document.getElementById('fin-total-cost').textContent = R(tc);
  document.getElementById('fin-profit').textContent = R(tp);
  document.getElementById('fin-margin').textContent = tm + '%';
  document.getElementById('financial-body').innerHTML = data.map(r =>
    '<tr><td class="order-num">TR4 #' + String(r.order_number).padStart(3, '0') + '</td><td>' + (r.orders?.customers?.name || '—') + '</td><td>' + R(r.total_sale) + '</td><td>' + R(r.total_cost) + '</td><td>' + R(r.shipping_cost) + '</td><td style="color:' + (r.profit >= 0 ? 'var(--green)' : 'var(--red)') + ';">' + R(r.profit) + '</td><td>' + r.margin_percent + '%</td></tr>'
  ).join('') || '<tr><td colspan="7" class="empty"><p>Sem dados financeiros.</p></td></tr>';
}

// ---- COSTS ----
async function loadCosts() {
  const { data } = await db.from('order_financials').select('*, orders(customers(name))');
  if (!data) return;
  document.getElementById('costs-body').innerHTML = data.map(r =>
    '<tr><td class="order-num">TR4 #' + String(r.order_number).padStart(3, '0') + '</td><td>' + (r.orders?.customers?.name || '—') + '</td><td>' + R(r.total_cost) + '</td><td>' + R(r.shipping_cost) + '</td><td style="color:var(--orange);">' + R(Number(r.total_cost) + Number(r.shipping_cost)) + '</td><td>' + R(r.total_sale) + '</td></tr>'
  ).join('') || '<tr><td colspan="6" class="empty"><p>Sem dados.</p></td></tr>';
  if (chartCosts) chartCosts.destroy();
  const labels = data.map(r => 'TR4 #' + String(r.order_number).padStart(3, '0'));
  const costs = data.map(r => Number(r.total_cost) + Number(r.shipping_cost));
  const sales = data.map(r => Number(r.total_sale));
  chartCosts = new Chart(document.getElementById('chart-costs'), {
    type: 'bar', data: { labels, datasets: [{ label: 'Custo', data: costs, backgroundColor: '#F25C0588', borderRadius: 3 }, { label: 'Receita', data: sales, backgroundColor: '#D4AF3788', borderRadius: 3 }] },
    options: { plugins: { legend: { labels: { color: '#888', font: { family: 'Barlow' } } } }, scales: { x: { ticks: { color: '#555' }, grid: { display: false } }, y: { ticks: { color: '#555', callback: v => 'R$' + v }, grid: { color: '#1a1a1a' } } }, responsive: true, maintainAspectRatio: false }
  });
}

// ---- SAVE CUSTOMER ----
async function saveCustomer() {
  const name = document.getElementById('c-name').value.trim();
  if (!name) { toast('O nome do cliente é obrigatório.', 'error'); return; }
  const cpf = document.getElementById('c-cpf').value.trim() || null;
  const payload = { name, cpf, phone: document.getElementById('c-phone').value.trim() || null, birth_date: document.getElementById('c-birth').value || null, favorite_team: document.getElementById('c-team').value.trim() || null, zip_code: document.getElementById('c-zip').value.trim() || null, street: document.getElementById('c-street').value.trim() || null, number: document.getElementById('c-number').value.trim() || null, complement: document.getElementById('c-complement').value.trim() || null, neighborhood: document.getElementById('c-neighborhood').value.trim() || null, city: document.getElementById('c-city').value.trim() || null, state: document.getElementById('c-state').value.trim().toUpperCase() || null, notes: document.getElementById('c-notes').value.trim() || null };
  const { error } = await db.from('customers').insert(payload);
  if (error) { toast(error.message.includes('unique') ? 'CPF já cadastrado para outro cliente.' : 'Erro ao salvar: ' + error.message, 'error'); return; }
  toast('Cliente cadastrado!');
  closeModal('modal-customer');
  ['c-name','c-cpf','c-phone','c-birth','c-team','c-zip','c-street','c-number','c-complement','c-neighborhood','c-city','c-state','c-notes'].forEach(id => document.getElementById(id).value = '');
  await loadAll();
}

// ---- CEP AUTO-FILL ----
async function fetchCep(val) {
  const cep = val.replace(/\D/g, '');
  if (cep.length !== 8) return;
  const r = await fetch('https://viacep.com.br/ws/' + cep + '/json/');
  const d = await r.json();
  if (!d.erro) {
    document.getElementById('c-street').value = d.logradouro || '';
    document.getElementById('c-neighborhood').value = d.bairro || '';
    document.getElementById('c-city').value = d.localidade || '';
    document.getElementById('c-state').value = d.uf || '';
  }
}

// ---- SAVE ORDER ----
let orderItems = [];

function addItem() {
  orderItems.push({ description: '', team: '', size: '', quantity: 1, cost: '', sale: '' });
  renderItems();
}

function removeItem(idx) { orderItems.splice(idx, 1); renderItems(); }

function renderItems() {
  const list = document.getElementById('items-list');
  if (!orderItems.length) { list.innerHTML = ''; return; }
  list.innerHTML = orderItems.map((it, i) =>
    '<div class="item-row"><input placeholder="Descrição *" value="' + it.description + '" oninput="orderItems[' + i + '].description=this.value" style="flex:2;"><input placeholder="Time" value="' + it.team + '" oninput="orderItems[' + i + '].team=this.value"><input placeholder="Tam." value="' + it.size + '" oninput="orderItems[' + i + '].size=this.value" style="max-width:60px;"><input type="number" placeholder="Qtd" value="' + it.quantity + '" min="1" oninput="orderItems[' + i + '].quantity=+this.value" style="max-width:55px;"><input type="number" placeholder="Custo R$" value="' + it.cost + '" min="0" step="0.01" oninput="orderItems[' + i + '].cost=this.value" style="max-width:90px;"><input type="number" placeholder="Venda R$" value="' + it.sale + '" min="0" step="0.01" oninput="orderItems[' + i + '].sale=this.value" style="max-width:90px;"><button class="item-remove" onclick="removeItem(' + i + ')">✕</button></div>'
  ).join('');
}

async function searchCustomers(q) {
  const res = document.getElementById('o-customer-results');
  if (q.length < 2) { res.style.display = 'none'; return; }
  const matches = allCustomers.filter(c => c.name.toLowerCase().includes(q.toLowerCase()) || (c.cpf || '').includes(q));
  res.style.display = matches.length ? 'block' : 'none';
  res.innerHTML = matches.slice(0, 6).map(c =>
    '<div onclick="selectCustomer(' + JSON.stringify(c).replace(/"/g, '&quot;') + ')" style="padding:10px 14px;cursor:pointer;border-bottom:1px solid var(--border);font-size:13px;" onmouseover="this.style.background=\'#1a1300\'" onmouseout="this.style.background=\'\'"><strong style="color:var(--gold);">' + c.name + '</strong> <span style="color:#666;font-size:11px;">' + (c.cpf || '') + '</span></div>'
  ).join('');
}

function selectCustomer(c) {
  selectedCustomerId = c.id;
  document.getElementById('o-customer-search').value = '';
  document.getElementById('o-customer-results').style.display = 'none';
  const sel = document.getElementById('o-customer-selected');
  sel.style.display = 'block';
  sel.innerHTML = '<strong>' + c.name + '</strong> · ' + (c.favorite_team ? c.favorite_team + ' · ' : '') + (c.phone || '');
}

async function saveOrder() {
  if (!selectedCustomerId) { toast('Selecione um cliente.', 'error'); return; }
  if (!orderItems.length) { toast('Adicione pelo menos um item.', 'error'); return; }
  if (orderItems.some(i => !i.description || !i.cost || !i.sale)) { toast('Preencha descrição, custo e preço de todos os itens.', 'error'); return; }
  const { data: order, error } = await db.from('orders').insert({ customer_id: selectedCustomerId, payment_method: document.getElementById('o-payment').value, shipping_cost: parseFloat(document.getElementById('o-shipping').value) || 0, notes: document.getElementById('o-notes').value.trim() || null }).select().single();
  if (error) { toast('Erro ao criar pedido.', 'error'); return; }
  const items = orderItems.map(i => ({ order_id: order.id, product_description: i.description, team: i.team || null, size: i.size || null, quantity: parseInt(i.quantity) || 1, cost_price: parseFloat(i.cost), sale_price: parseFloat(i.sale) }));
  const { error: itemsError } = await db.from('order_items').insert(items);
  if (itemsError) { toast('Erro ao salvar itens.', 'error'); return; }
  toast('Pedido TR4 #' + String(order.order_number).padStart(3, '0') + ' criado!');
  closeModal('modal-order');
  orderItems = []; selectedCustomerId = null;
  document.getElementById('o-customer-selected').style.display = 'none';
  document.getElementById('o-notes').value = '';
  document.getElementById('o-shipping').value = '0';
  renderItems();
  await loadAll();
}

// ---- ORDER DETAIL ----
function showOrderDetail(order) {
  const total = order.order_items.reduce((a, i) => a + i.sale_price * i.quantity, 0);
  const cost = order.order_items.reduce((a, i) => a + i.cost_price * i.quantity, 0);
  const profit = total - cost - Number(order.shipping_cost);
  const stepIdx = STATUS_KEYS.indexOf(order.status);
  const stepper = STATUS_KEYS.map((k, i) => '<div class="step ' + (i < stepIdx ? 'done' : i === stepIdx ? 'current' : '') + '">' + STATUSES[k] + '</div>').join('');
  document.getElementById('order-detail-content').innerHTML =
    '<div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:20px;">' +
      '<div><div style="font-family:Barlow Condensed,sans-serif;font-size:22px;font-weight:700;color:var(--gold);">TR4 #' + String(order.order_number).padStart(3, '0') + '</div>' +
      '<div style="font-size:13px;color:#888;margin-top:2px;">' + fmtDate(order.created_at) + ' · ' + (order.payment_method === 'pix' ? 'Pix' : 'Cartão') + '</div></div>' +
      '<div>' + badgeStatus(order.status) + '</div>' +
    '</div>' +
    '<div style="margin-bottom:16px;"><div style="font-size:10px;color:#555;text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;">Jornada do manto</div><div class="stepper">' + stepper + '</div></div>' +
    '<div style="margin-bottom:16px;"><div style="font-size:10px;color:#555;text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;">Torcedor</div><div style="font-size:15px;font-weight:500;">' + (order.customers?.name || '—') + '</div></div>' +
    '<div style="margin-bottom:16px;"><div style="font-size:10px;color:#555;text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;">Mantos do pedido</div>' +
    order.order_items.map(i => '<div style="display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--border);"><div><div style="font-size:13px;">' + i.product_description + '</div><div style="font-size:11px;color:#666;margin-top:2px;">' + [i.team, i.size, 'Qtd: ' + i.quantity].filter(Boolean).join(' · ') + '</div></div><div style="text-align:right;"><div style="color:var(--gold);font-weight:600;">' + R(i.sale_price * i.quantity) + '</div><div style="font-size:11px;color:#555;">Custo: ' + R(i.cost_price * i.quantity) + '</div></div></div>').join('') +
    '</div>' +
    '<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:16px;">' +
      '<div style="background:#111;border-radius:8px;padding:12px;text-align:center;"><div style="font-size:10px;color:#555;margin-bottom:4px;">RECEITA</div><div style="font-family:Barlow Condensed,sans-serif;font-size:18px;color:var(--gold);">' + R(total) + '</div></div>' +
      '<div style="background:#111;border-radius:8px;padding:12px;text-align:center;"><div style="font-size:10px;color:#555;margin-bottom:4px;">CUSTO TOTAL</div><div style="font-family:Barlow Condensed,sans-serif;font-size:18px;color:var(--orange);">' + R(cost + Number(order.shipping_cost)) + '</div></div>' +
      '<div style="background:#111;border-radius:8px;padding:12px;text-align:center;"><div style="font-size:10px;color:#555;margin-bottom:4px;">LUCRO</div><div style="font-family:Barlow Condensed,sans-serif;font-size:18px;color:' + (profit >= 0 ? 'var(--green)' : 'var(--red)') + ';">' + R(profit) + '</div></div>' +
    '</div>' +
    '<div style="display:flex;gap:10px;justify-content:flex-end;margin-top:8px;">' +
      '<select onchange="updateStatus(\'' + order.id + '\', this.value)" style="background:#111;border:1px solid var(--border-light);border-radius:7px;padding:8px 12px;font-size:12px;color:var(--text);font-family:Barlow,sans-serif;">' +
        STATUS_KEYS.map(k => '<option value="' + k + '"' + (k === order.status ? ' selected' : '') + '>' + STATUSES[k] + '</option>').join('') +
      '</select>' +
    '</div>';
  openModal('modal-order-detail');
}

async function updateStatus(orderId, status) {
  const { error } = await db.from('orders').update({ status }).eq('id', orderId);
  if (error) { toast('Erro ao atualizar status.', 'error'); return; }
  toast('Status atualizado!');
  await loadAll();
}

// ---- MASKS ----
function maskPhone(input) {
  let v = input.value.replace(/\D/g, '').slice(0, 11);
  if (v.length <= 2) v = v.replace(/^(\d{0,2})/, '($1');
  else if (v.length <= 6) v = v.replace(/^(\d{2})(\d{0,4})/, '($1) $2');
  else if (v.length <= 10) v = v.replace(/^(\d{2})(\d{4})(\d{0,4})/, '($1) $2-$3');
  else v = v.replace(/^(\d{2})(\d{5})(\d{0,4})/, '($1) $2-$3');
  input.value = v;
}

function maskCpf(input) {
  let v = input.value.replace(/\D/g, '').slice(0, 11);
  if (v.length <= 3) v = v;
  else if (v.length <= 6) v = v.replace(/^(\d{3})(\d{0,3})/, '$1.$2');
  else if (v.length <= 9) v = v.replace(/^(\d{3})(\d{3})(\d{0,3})/, '$1.$2.$3');
  else v = v.replace(/^(\d{3})(\d{3})(\d{3})(\d{0,2})/, '$1.$2.$3-$4');
  input.value = v;
}

// ---- INIT ----
addItem();
loadAll();
</script>
