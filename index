<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TR4 Store — Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600&family=Barlow+Condensed:wght@600;700&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
<style>
  *{margin:0;padding:0;box-sizing:border-box;}
  :root{
    --gold:#D4AF37;--gold-light:#EAD27A;--orange:#F25C05;
    --bg:#0a0a0a;--sidebar:#0f0f0f;--panel:#141414;--card:#1a1a1a;
    --border:#222;--border-light:#2a2a2a;
    --text:#f0f0f0;--text-muted:#666;--text-dim:#444;
    --green:#4caf7d;--red:#e05252;
  }
  html,body{height:100%;background:var(--bg);color:var(--text);font-family:'Barlow',sans-serif;font-size:14px;}
  .layout{display:flex;height:100vh;overflow:hidden;}

  /* SIDEBAR */
  .sidebar{width:220px;background:var(--sidebar);border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0;}
  .sidebar-logo{padding:20px 18px 16px;border-bottom:1px solid var(--border);}
  .sidebar-logo img{width:130px;height:auto;display:block;}
  .sidebar-logo-slogan{font-size:9px;color:#3a2e10;margin-top:6px;letter-spacing:0.3px;}
  .sidebar-nav{padding:10px 0;flex:1;overflow-y:auto;}
  .nav-section{font-size:9px;color:var(--text-dim);letter-spacing:2px;text-transform:uppercase;padding:14px 18px 5px;}
  .nav-item{display:flex;align-items:center;gap:10px;padding:9px 18px;font-size:13px;color:var(--text-muted);cursor:pointer;border-left:2px solid transparent;transition:all .15s;}
  .nav-item:hover{color:#aaa;background:#161616;}
  .nav-item.active{color:var(--gold);border-left:2px solid var(--gold);background:#1a1300;}
  .nav-item svg{width:16px;height:16px;flex-shrink:0;stroke:currentColor;fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round;}

  /* MAIN */
  .main{flex:1;display:flex;flex-direction:column;overflow:hidden;}
  .topbar{padding:14px 24px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;background:var(--sidebar);flex-shrink:0;}
  .topbar-title{font-family:'Barlow Condensed',sans-serif;font-size:18px;font-weight:700;color:var(--text);letter-spacing:.5px;}
  .topbar-actions{display:flex;gap:8px;}
  .btn{padding:7px 16px;border-radius:7px;font-size:12px;font-weight:600;cursor:pointer;border:none;font-family:'Barlow',sans-serif;transition:opacity .15s;}
  .btn:hover{opacity:.85;}
  .btn-gold{background:linear-gradient(135deg,var(--gold),var(--orange));color:#000;}
  .btn-outline{background:transparent;border:1px solid var(--border-light);color:var(--text-muted);}
  .content{flex:1;overflow-y:auto;padding:22px 24px;}

  /* VIEWS */
  .view{display:none;}
  .view.active{display:block;}

  /* CARDS */
  .cards-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:22px;}
  .metric-card{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:16px;}
  .metric-card .label{font-size:10px;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;}
  .metric-card .value{font-family:'Barlow Condensed',sans-serif;font-size:26px;font-weight:700;}
  .metric-card .sub{font-size:10px;color:var(--text-dim);margin-top:4px;}
  .v-gold{color:var(--gold);}
  .v-orange{color:var(--orange);}
  .v-green{color:var(--green);}
  .v-white{color:var(--text);}

  /* PANELS */
  .panels-row{display:grid;grid-template-columns:1.5fr 1fr;gap:16px;margin-bottom:22px;}
  .panel{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:18px;}
  .panel-title{font-size:10px;color:var(--text-muted);text-transform:uppercase;letter-spacing:1.2px;margin-bottom:16px;}

  /* STATUS BARS */
  .status-bar-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;}
  .status-bar-label{font-size:12px;color:#999;}
  .status-bar-right{display:flex;align-items:center;gap:10px;}
  .status-bar-track{width:90px;height:4px;background:#1f1f1f;border-radius:2px;overflow:hidden;}
  .status-bar-fill{height:100%;border-radius:2px;}

  /* ORDERS TABLE */
  .section-label{font-size:10px;color:var(--text-muted);text-transform:uppercase;letter-spacing:1.2px;margin-bottom:12px;}
  .orders-table{width:100%;border-collapse:collapse;}
  .orders-table th{font-size:10px;color:var(--text-dim);text-transform:uppercase;letter-spacing:1px;padding:8px 10px;text-align:left;border-bottom:1px solid var(--border);}
  .orders-table td{padding:10px 10px;border-bottom:1px solid var(--border);font-size:13px;}
  .orders-table tr:last-child td{border-bottom:none;}
  .orders-table tr:hover td{background:#161616;}
  .order-num{font-family:'Barlow Condensed',sans-serif;color:var(--gold);font-weight:700;font-size:13px;}
  .badge{display:inline-block;padding:3px 9px;border-radius:20px;font-size:10px;font-weight:600;white-space:nowrap;}
  .badge-gold{background:#1a1300;color:var(--gold);}
  .badge-green{background:#0d1f0d;color:var(--green);}
  .badge-orange{background:#1f0e00;color:var(--orange);}
  .badge-gray{background:#1a1a1a;color:#666;}

  /* FORMS */
  .form-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
  .form-grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;}
  .form-group{display:flex;flex-direction:column;gap:5px;}
  .form-group.full{grid-column:1/-1;}
  .form-group label{font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.8px;}
  .form-group input,.form-group select,.form-group textarea{
    background:#111;border:1px solid var(--border-light);border-radius:7px;
    padding:9px 12px;font-size:13px;color:var(--text);font-family:'Barlow',sans-serif;
    outline:none;transition:border-color .15s;
  }
  .form-group input:focus,.form-group select:focus,.form-group textarea:focus{border-color:var(--gold);}
  .form-group textarea{resize:vertical;min-height:80px;}
  .form-section-title{font-family:'Barlow Condensed',sans-serif;font-size:15px;font-weight:700;color:var(--gold);letter-spacing:.5px;margin:20px 0 12px;padding-bottom:8px;border-bottom:1px solid var(--border);}
  .form-actions{display:flex;gap:10px;margin-top:24px;justify-content:flex-end;}

  /* CUSTOMERS TABLE */
  .table-wrap{background:var(--card);border:1px solid var(--border);border-radius:10px;overflow:hidden;}
  .table-header{display:flex;justify-content:space-between;align-items:center;padding:16px 18px;border-bottom:1px solid var(--border);}
  .table-header-title{font-family:'Barlow Condensed',sans-serif;font-size:15px;font-weight:700;color:var(--text);}
  .data-table{width:100%;border-collapse:collapse;}
  .data-table th{font-size:10px;color:var(--text-dim);text-transform:uppercase;letter-spacing:1px;padding:10px 18px;text-align:left;background:#111;border-bottom:1px solid var(--border);}
  .data-table td{padding:11px 18px;border-bottom:1px solid var(--border);font-size:13px;color:var(--text);}
  .data-table tr:last-child td{border-bottom:none;}
  .data-table tr:hover td{background:#161616;cursor:pointer;}
  .avatar{width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,#1a1300,#3a2900);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:var(--gold);flex-shrink:0;}
  .customer-cell{display:flex;align-items:center;gap:10px;}

  /* TOAST */
  .toast{position:fixed;bottom:24px;right:24px;padding:12px 20px;border-radius:8px;font-size:13px;font-weight:500;z-index:9999;opacity:0;transition:opacity .3s;}
  .toast.show{opacity:1;}
  .toast-success{background:var(--green);color:#000;}
  .toast-error{background:var(--red);color:#fff;}

  /* MODAL */
  .modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:1000;align-items:center;justify-content:center;}
  .modal-bg.open{display:flex;}
  .modal{background:var(--panel);border:1px solid var(--border-light);border-radius:14px;padding:28px;width:640px;max-width:95vw;max-height:90vh;overflow-y:auto;}
  .modal-title{font-family:'Barlow Condensed',sans-serif;font-size:20px;font-weight:700;color:var(--gold);margin-bottom:20px;}
  .modal-close{float:right;cursor:pointer;color:var(--text-muted);font-size:20px;line-height:1;background:none;border:none;color:#666;}
  .modal-close:hover{color:var(--text);}

  /* EMPTY STATE */
  .empty{text-align:center;padding:48px;color:var(--text-muted);}
  .empty svg{width:40px;height:40px;margin:0 auto 12px;stroke:var(--text-dim);}
  .empty p{font-size:13px;}

  /* LOADING */
  .loading{text-align:center;padding:32px;color:var(--text-dim);font-size:13px;}

  /* ITEMS LIST (pedido) */
  .items-list{border:1px solid var(--border);border-radius:8px;overflow:hidden;margin-bottom:12px;}
  .item-row{display:flex;align-items:center;gap:10px;padding:10px 14px;border-bottom:1px solid var(--border);background:#111;}
  .item-row:last-child{border-bottom:none;}
  .item-row input,.item-row select{flex:1;background:transparent;border:none;border-radius:4px;padding:4px 6px;font-size:12px;color:var(--text);font-family:'Barlow',sans-serif;}
  .item-row input:focus,.item-row select:focus{outline:1px solid var(--gold);}
  .item-remove{background:none;border:none;color:#555;cursor:pointer;padding:4px;border-radius:4px;}
  .item-remove:hover{color:var(--red);}
  .add-item-btn{width:100%;padding:8px;border:1px dashed var(--border-light);border-radius:7px;background:transparent;color:var(--text-muted);font-size:12px;cursor:pointer;font-family:'Barlow',sans-serif;}
  .add-item-btn:hover{border-color:var(--gold);color:var(--gold);}

  /* STEPPER */
  .stepper{display:flex;gap:4px;flex-wrap:wrap;margin-bottom:4px;}
  .step{flex:1;min-width:80px;text-align:center;padding:6px 4px;border-radius:5px;font-size:9px;color:var(--text-dim);background:#111;border:1px solid var(--border);cursor:default;}
  .step.done{background:#0d1a00;border-color:#2a4a00;color:#6abf3a;}
  .step.current{background:#1a1300;border-color:var(--gold);color:var(--gold);font-weight:600;}

  select option{background:#1a1a1a;}
</style>
</head>
<body>

<div class="layout">
  <!-- SIDEBAR -->
  <aside class="sidebar">
    <div class="sidebar-logo">
      <img src="data:image/png;base64," alt="TR4 Store">
      <div class="sidebar-logo-slogan">Sua paixão. Seu manto. Seu jogo.</div>
    </div>
    <nav class="sidebar-nav">
      <div class="nav-section">Principal</div>
      <div class="nav-item active" onclick="navigate('overview')">
        <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        Visão geral
      </div>
      <div class="nav-item" onclick="navigate('orders')">
        <svg viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        Pedidos
      </div>
      <div class="nav-item" onclick="navigate('customers')">
        <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        Clientes
      </div>
      <div class="nav-section">Financeiro</div>
      <div class="nav-item" onclick="navigate('financial')">
        <svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        Faturamento
      </div>
      <div class="nav-item" onclick="navigate('costs')">
        <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14,2 14,8 20,8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10,9 9,9 8,9"/></svg>
        Custos
      </div>
    </nav>
  </aside>

  <!-- MAIN -->
  <main class="main">
    <div class="topbar">
      <div class="topbar-title" id="topbar-title">Visão geral</div>
      <div class="topbar-actions">
        <button class="btn btn-outline" id="topbar-secondary-btn" style="display:none"></button>
        <button class="btn btn-gold" id="topbar-primary-btn" onclick="handlePrimaryAction()">+ Novo pedido</button>
      </div>
    </div>

    <div class="content">

      <!-- VISÃO GERAL -->
      <div class="view active" id="view-overview">
        <div class="cards-grid">
          <div class="metric-card"><div class="label">Faturamento do mês</div><div class="value v-gold" id="kpi-revenue">—</div><div class="sub" id="kpi-revenue-sub"></div></div>
          <div class="metric-card"><div class="label">Lucro líquido</div><div class="value v-green" id="kpi-profit">—</div><div class="sub" id="kpi-margin-sub"></div></div>
          <div class="metric-card"><div class="label">Pedidos</div><div class="value v-orange" id="kpi-orders">—</div><div class="sub" id="kpi-orders-sub"></div></div>
          <div class="metric-card"><div class="label">Clientes</div><div class="value v-white" id="kpi-customers">—</div><div class="sub" id="kpi-customers-sub"></div></div>
        </div>
        <div class="panels-row">
          <div class="panel">
            <div class="panel-title">Vendas — últimos 6 meses</div>
            <canvas id="chart-sales" height="110"></canvas>
          </div>
          <div class="panel">
            <div class="panel-title">Status dos pedidos</div>
            <div id="status-summary"></div>
          </div>
        </div>
        <div class="section-label">Pedidos recentes</div>
        <table class="orders-table">
          <thead><tr>
            <th>Nº</th><th>Cliente</th><th>Produto</th><th>Status</th><th>Pagamento</th><th style="text-align:right">Valor</th>
          </tr></thead>
          <tbody id="recent-orders-body"><tr><td colspan="6" class="loading">Carregando...</td></tr></tbody>
        </table>
      </div>

      <!-- PEDIDOS -->
      <div class="view" id="view-orders">
        <div class="table-wrap">
          <div class="table-header">
            <div class="table-header-title">Todos os pedidos</div>
            <input type="text" placeholder="Buscar pedido..." style="background:#111;border:1px solid var(--border-light);border-radius:7px;padding:7px 12px;font-size:13px;color:var(--text);width:220px;outline:none;" oninput="filterOrders(this.value)">
          </div>
          <table class="data-table">
            <thead><tr><th>Nº</th><th>Cliente</th><th>Itens</th><th>Status</th><th>Pagamento</th><th>Data</th><th style="text-align:right">Valor</th></tr></thead>
            <tbody id="orders-body"><tr><td colspan="7" class="loading">Carregando...</td></tr></tbody>
          </table>
        </div>
      </div>

      <!-- CLIENTES -->
      <div class="view" id="view-customers">
        <div class="table-wrap">
          <div class="table-header">
            <div class="table-header-title">Clientes cadastrados</div>
            <input type="text" placeholder="Buscar cliente..." style="background:#111;border:1px solid var(--border-light);border-radius:7px;padding:7px 12px;font-size:13px;color:var(--text);width:220px;outline:none;" oninput="filterCustomers(this.value)">
          </div>
          <table class="data-table">
            <thead><tr><th>Cliente</th><th>Telefone</th><th>Time do coração</th><th>Cidade</th><th>Cadastro</th></tr></thead>
            <tbody id="customers-body"><tr><td colspan="5" class="loading">Carregando...</td></tr></tbody>
          </table>
        </div>
      </div>

      <!-- FATURAMENTO -->
      <div class="view" id="view-financial">
        <div class="cards-grid">
          <div class="metric-card"><div class="label">Total vendido</div><div class="value v-gold" id="fin-total-sale">—</div></div>
          <div class="metric-card"><div class="label">Custo total</div><div class="value v-orange" id="fin-total-cost">—</div></div>
          <div class="metric-card"><div class="label">Lucro líquido</div><div class="value v-green" id="fin-profit">—</div></div>
          <div class="metric-card"><div class="label">Margem média</div><div class="value v-white" id="fin-margin">—</div></div>
        </div>
        <div class="table-wrap" style="margin-top:8px;">
          <div class="table-header"><div class="table-header-title">Resultado por pedido</div></div>
          <table class="data-table">
            <thead><tr><th>Nº</th><th>Cliente</th><th>Venda</th><th>Custo</th><th>Frete</th><th>Lucro</th><th>Margem</th></tr></thead>
            <tbody id="financial-body"><tr><td colspan="7" class="loading">Carregando...</td></tr></tbody>
          </table>
        </div>
      </div>

      <!-- CUSTOS -->
      <div class="view" id="view-costs">
        <div class="panel" style="margin-bottom:16px;">
          <div class="panel-title">Composição dos custos</div>
          <canvas id="chart-costs" height="200"></canvas>
        </div>
        <div class="table-wrap">
          <div class="table-header"><div class="table-header-title">Detalhe de custos</div></div>
          <table class="data-table">
            <thead><tr><th>Nº Pedido</th><th>Cliente</th><th>Custo produto</th><th>Frete/taxas</th><th>Custo total</th><th>Receita</th></tr></thead>
            <tbody id="costs-body"><tr><td colspan="6" class="loading">Carregando...</td></tr></tbody>
          </table>
        </div>
      </div>

    </div><!-- .content -->
  </main>
</div>

<!-- MODAL: NOVO CLIENTE -->
<div class="modal-bg" id="modal-customer">
  <div class="modal">
    <button class="modal-close" onclick="closeModal('modal-customer')">✕</button>
    <div class="modal-title">Cadastrar cliente</div>
    <div class="form-section-title">Dados pessoais</div>
    <div class="form-grid">
      <div class="form-group"><label>Nome completo *</label><input type="text" id="c-name" placeholder="Ex: Carlos Eduardo Lima"></div>
      <div class="form-group"><label>CPF</label><input type="text" id="c-cpf" placeholder="000.000.000-00" maxlength="14" oninput="maskCpf(this)"></div>
      <div class="form-group"><label>Telefone</label><input type="text" id="c-phone" placeholder="(11) 91234-5678" maxlength="16" oninput="maskPhone(this)"></div>
      <div class="form-group"><label>Data de nascimento</label><input type="date" id="c-birth"></div>
      <div class="form-group full"><label>Time do coração</label><input type="text" id="c-team" placeholder="Ex: Flamengo, Corinthians..."></div>
    </div>
    <div class="form-section-title">Endereço</div>
    <div class="form-grid">
      <div class="form-group"><label>CEP</label><input type="text" id="c-zip" placeholder="00000-000" maxlength="9" oninput="fetchCep(this.value)"></div>
      <div class="form-group"><label>Estado (UF)</label><input type="text" id="c-state" placeholder="SP" maxlength="2"></div>
      <div class="form-group full"><label>Logradouro</label><input type="text" id="c-street" placeholder="Rua, Av..."></div>
      <div class="form-group"><label>Número</label><input type="text" id="c-number" placeholder="123"></div>
      <div class="form-group"><label>Complemento</label><input type="text" id="c-complement" placeholder="Apto, Bloco..."></div>
      <div class="form-group"><label>Bairro</label><input type="text" id="c-neighborhood" placeholder="Centro"></div>
      <div class="form-group"><label>Cidade</label><input type="text" id="c-city" placeholder="São Paulo"></div>
    </div>
    <div class="form-section-title">Observações</div>
    <div class="form-group"><textarea id="c-notes" placeholder="Informações adicionais sobre o cliente..."></textarea></div>
    <div class="form-actions">
      <button class="btn btn-outline" onclick="closeModal('modal-customer')">Cancelar</button>
      <button class="btn btn-gold" onclick="saveCustomer()">Salvar cliente</button>
    </div>
  </div>
</div>

<!-- MODAL: NOVO PEDIDO -->
<div class="modal-bg" id="modal-order">
  <div class="modal" style="width:720px;">
    <button class="modal-close" onclick="closeModal('modal-order')">✕</button>
    <div class="modal-title">Novo pedido</div>
    <div class="form-section-title">Cliente</div>
    <div class="form-group">
      <label>Buscar cliente (nome ou CPF) *</label>
      <input type="text" id="o-customer-search" placeholder="Digite para buscar..." oninput="searchCustomers(this.value)">
      <div id="o-customer-results" style="background:#111;border:1px solid var(--border-light);border-radius:7px;margin-top:4px;display:none;max-height:160px;overflow-y:auto;"></div>
      <div id="o-customer-selected" style="display:none;margin-top:8px;padding:10px 12px;background:#1a1300;border:1px solid var(--gold);border-radius:7px;font-size:13px;color:var(--gold);"></div>
    </div>
    <div class="form-section-title">Itens do pedido</div>
    <div style="font-size:10px;color:var(--text-dim);margin-bottom:8px;">Descrição · Time · Tam. · Qtd · Custo unit. · Preço venda unit.</div>
    <div class="items-list" id="items-list"></div>
    <button class="add-item-btn" onclick="addItem()">+ Adicionar item</button>
    <div class="form-section-title">Dados do pedido</div>
    <div class="form-grid">
      <div class="form-group">
        <label>Pagamento *</label>
        <select id="o-payment">
          <option value="pix">Pix</option>
          <option value="cartao_credito">Cartão de crédito</option>
        </select>
      </div>
